# Local development only — copy to .env and load with your tooling.
# Cloud Run does NOT read .env from the image; set these as service env vars or Secret Manager.

PROJECT_ID=admind-data-organisation
DATASET=admind_data_organisation
LOCATION=europe-west4

# gemini | openai | auto (try Gemini, then OpenAI if Gemini fails)
LLM_PROVIDER=auto
MODEL_NAME=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

JOB_TYPE=taxonomy-sync
PROJECT_LIMIT=20
DOCUMENT_LIMIT=200
