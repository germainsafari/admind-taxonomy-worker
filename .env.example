# Local development only — copy to .env and load with your tooling.
# Cloud Run does NOT read .env; set these as job env vars or Secret Manager secrets.

# ── GCP ─────────────────────────────────────────────────────────────────────
PROJECT_ID=admind-data-organisation
DATASET=admind_data_organisation
LOCATION=europe-west4
FIRESTORE_DATABASE=admindfirestore

# ── LLM ─────────────────────────────────────────────────────────────────────
# auto  → Gemini API key → Vertex AI Gemini (service account) → OpenAI
# gemini → Gemini API key → Vertex AI Gemini (no OpenAI fallback)
# openai → OpenAI only
LLM_PROVIDER=auto

# Gemini Developer API (AI Studio) — PRIMARY when set
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

MODEL_NAME=gemini-2.5-flash

# OpenAI — FALLBACK (only needed when Gemini is unavailable and LLM_PROVIDER=auto)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Scoro ────────────────────────────────────────────────────────────────────
SCORO_BASE_URL=https://admindagency.scoro.com
SCORO_API_KEY=
SCORO_COMPANY_ACCOUNT_ID=

# ── Gemini Enterprise / Discovery Engine ─────────────────────────────────────
DISCOVERY_ENGINE_PROJECT_NUMBER=493121771508
DISCOVERY_ENGINE_PROJECT=admind-data-organisation
DISCOVERY_ENGINE_LOCATION=global
DISCOVERY_ENGINE_COLLECTION=default_collection
DISCOVERY_ENGINE_ENGINE_ID=gemini-enterprise-admind
DISCOVERY_ENGINE_SERVING_CONFIG=default_search
# Google Drive / Workspace data stores reject service-account search.
# Set this to a licensed Workspace user to impersonate via domain-wide delegation.
DISCOVERY_IMPERSONATE_USER=germain.safari@admindagency.com

# ── Job control ──────────────────────────────────────────────────────────────
# scoro-sync | document-discovery | taxonomy-sync | wiki-generate
# | wiki-generate-one | full-sync | historical-full-sync
JOB_TYPE=full-sync

# How many projects to process per run.
PROJECT_LIMIT=20
# Discovery Engine page size per search query.
DOCUMENT_LIMIT=25
# Max per-project candidate documents the classifier sees (defaults to DOCUMENT_LIMIT).
CANDIDATE_LIMIT=50

# Which projects to PROCESS from BigQuery (discovery/taxonomy/wiki):
#   active → open projects only (default)   all → every project incl. completed
PROJECT_MODE=active
# Which projects to FETCH from Scoro (scoro-sync):
#   active → status=inprogress only (default)   all → every status (backfill)
SCORO_PROJECT_MODE=active

# Required only for wiki-generate-one:
PROJECT_ID_TO_GENERATE=
